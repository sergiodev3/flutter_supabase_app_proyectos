# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno de Supabase  —  EJEMPLO (copia esto a ".env")
# ─────────────────────────────────────────────────────────────────────────────
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena los valores con los de tu proyecto en https://supabase.com
#   3. NUNCA subas el .env real al repositorio (ya está en .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# URL de tu proyecto Supabase → Project Settings > API > Project URL
SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anónima → Project Settings > API > anon public
# Esta clave es segura para el cliente: las políticas RLS la protegen.
SUPABASE_ANON_KEY=tu-anon-key-aqui
